"""
Number Guessing Game
Difficulty: Easy
Concepts: Loops, Conditionals, random module
"""

import random


def get_valid_guess(min_val, max_val):
    """Get a valid integer guess from the user."""
    while True:
        try:
            guess = int(input(f"Enter your guess ({min_val}-{max_val}): "))
            if min_val <= guess <= max_val:
                return guess
            print(f"Please enter a number between {min_val} and {max_val}.")
        except ValueError:
            print("Invalid input. Please enter a whole number.")


def play_round():
    """Play one round of the guessing game."""
    secret_number = random.randint(1, 100)
    max_attempts = 7
    attempts = 0

    print("\n" + "=" * 40)
    print("🎯 NUMBER GUESSING GAME")
    print("=" * 40)
    print("I'm thinking of a number between 1 and 100.")
    print(f"You have {max_attempts} attempts. Good luck!\n")

    while attempts < max_attempts:
        remaining = max_attempts - attempts
        print(f"Attempts remaining: {remaining}")
        guess = get_valid_guess(1, 100)
        attempts += 1

        if guess == secret_number:
            print(f"\n🎉 Congratulations! You guessed it in {attempts} attempt(s)!")
            return True
        elif guess < secret_number:
            print("📉 Too low! Try a higher number.\n")
        else:
            print("📈 Too high! Try a lower number.\n")

    print(f"\n😢 Game Over! The number was: {secret_number}")
    return False


def main():
    """Main game loop with score tracking."""
    wins = 0
    losses = 0

    print("Welcome to the Number Guessing Game!")

    while True:
        if play_round():
            wins += 1
        else:
            losses += 1

        print(f"\n📊 Score: {wins} wins | {losses} losses")

        again = input("\nPlay again? (y/n): ").strip().lower()
        if again not in ('y', 'yes'):
            print("\nThanks for playing! 👋")
            break


if __name__ == "__main__":
    main()
